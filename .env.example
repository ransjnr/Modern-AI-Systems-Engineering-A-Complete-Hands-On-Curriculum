# ============================================================
#  10-Day Tech Giants Sprint — environment variables
#  Copy to .env and fill in. NEVER commit your real .env.
# ============================================================

# --- OpenAI (Day 2 onward: RAG, agents, eval) ---
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Pinecone (Day 2: vector database) ---
PINECONE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PINECONE_INDEX=sprint-index

# --- Tavily (Day 4: web search for agents) ---
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- LangSmith (Day 7: tracing & evaluation) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_PROJECT=tech-giants-sprint

# --- MLflow (Day 1: experiment tracking) ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Redis (Day 8: caching & rate limiting) ---
REDIS_URL=redis://localhost:6379/0

# --- Default model used across the sprint (cheap & capable) ---
DEFAULT_MODEL=gpt-4o-mini
